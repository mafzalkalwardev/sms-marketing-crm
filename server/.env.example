PORT=5000
JWT_SECRET=change_me_to_a_strong_random_secret
MASTER_ENCRYPTION_KEY=change_me_to_a_32_byte_secret_or_use_jwt

DATABASE_URL=postgresql://signalmint:signalmint@localhost:5434/signalmint
DATABASE_SSL=false
AUTO_SEED=true

# Sandbox (set both false for live SMS)
VONAGE_MOCK_MODE=true
SMS_SANDBOX_MODE=true

# Vonage live
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_SIGNATURE_SECRET=your_vonage_signed_webhook_signature_secret
VONAGE_DEFAULT_FROM=+15551234567

# Twilio live
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_DEFAULT_FROM=+15551234567

# Required in production for Twilio webhook signature validation
# Render sets RENDER_EXTERNAL_URL automatically; Vercel sets VERCEL_URL.
# Override explicitly when using a custom domain:
PUBLIC_BACKEND_URL=https://signalmint-api.vercel.app

# Provider health cron (default every 5 min)
PROVIDER_HEALTH_ENABLED=true
PROVIDER_HEALTH_INTERVAL_MS=300000

AUTOMATION_WORKER_URL=http://localhost:5055
WORKER_SERVICE_TOKEN=change_me_worker_token
BROWSER_POLL_ENABLED=true
CAMPAIGN_QUEUE_ENABLED=true
# BullMQ when REDIS_URL is set (auto driver)
REDIS_URL=redis://localhost:6380
CAMPAIGN_QUEUE_DRIVER=auto
CAMPAIGN_WORKER_CONCURRENCY=5

# Message retention purge (org-level days set in Admin → Branding)
MESSAGE_RETENTION_ENABLED=true
MESSAGE_RETENTION_INTERVAL_MS=86400000

# Auth / OTP (dev: codes logged to console when OTP_LOG_TO_CONSOLE=true)
OTP_LOG_TO_CONSOLE=true
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
REQUIRE_ADMIN_APPROVAL=true
AUTH_SMS_FROM=+15551234567

# Email OTP — Resend (preferred) or SMTP
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@signalmint.local
SMTP_SECURE=false
